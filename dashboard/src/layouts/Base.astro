---
import "@/styles/global.css";
import { Sidebar } from "@/components/Sidebar";
import type { SessionSummary } from "@/lib/sessions";

interface Props {
  title?: string;
  headerStats?: {
    spendUsd: number;
    turns: number;
    sessions: number;
    activeSession?: string | null;
    /** Trailing $/min burn rate. Hidden when null/0. */
    burnUsdPerMin?: number | null;
    /** Fraction of recent turns that failed (0..1). Hidden when null/0. */
    errorRate?: number | null;
    /** Most-recent rate-limit snapshot from Anthropic's response headers. */
    rateLimit?: {
      tokRemaining: number;
      tokLimit: number;
    } | null;
  };
  /** Full session list for the sidebar nav. */
  sessions?: SessionSummary[];
  /** Highlighted session in the sidebar (on drilldown pages). */
  currentSessionId?: string | null;
}
const {
  title = "llmetry",
  headerStats,
  sessions = [],
  currentSessionId = null,
} = Astro.props;

function fmtUsd(n: number): string {
  if (n === 0) return "$0.00";
  if (n < 0.01) return `$${n.toFixed(4)}`;
  return `$${n.toFixed(2)}`;
}

function fmtBurn(n: number): string {
  if (n < 0.01) return `$${n.toFixed(4)}/min`;
  return `$${n.toFixed(2)}/min`;
}

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <script is:inline>
      document.documentElement.setAttribute("data-session-filter", "active");
    </script>
  </head>
  <body class="flex min-h-screen">
    <Sidebar
      client:load
      sessions={sessions}
      currentSessionId={currentSessionId}
    />
    <div class="flex-1 flex flex-col min-w-0">
    <header class="sticky top-0 z-20 backdrop-blur-xl bg-[var(--color-background)]/80 border-b border-[var(--color-border)]">
      <div class="px-6 h-14 flex items-center justify-between gap-6">
        <div class="flex items-center gap-6">
          <span class="text-xs text-[var(--color-muted-foreground)] hidden sm:inline">Claude Code observability</span>
          {
            headerStats && (
              <div
                data-live-region="header-stats"
                class="hidden md:flex items-center gap-3 pl-4 border-l border-[var(--color-border)] text-xs text-[var(--color-muted-foreground)]"
              >
                {headerStats.activeSession ? (
                  <span class="flex items-center gap-1.5">
                    <span class="live-dot" />
                    <span class="font-medium text-[var(--color-good)]">active</span>
                    <code class="font-mono text-[var(--color-foreground)] text-[0.6875rem]">
                      {headerStats.activeSession}
                    </code>
                  </span>
                ) : (
                  <span class="flex items-center gap-1.5">
                    <span class="inline-block w-2 h-2 rounded-full bg-[var(--color-subtle-foreground)]" />
                    <span class="font-medium text-[var(--color-muted-foreground)]">idle</span>
                  </span>
                )}
                <span class="text-[var(--color-subtle-foreground)]">·</span>
                <span class="tabular-nums font-mono">
                  <span class="text-[var(--color-money)] font-medium">{fmtUsd(headerStats.spendUsd)}</span>
                </span>
                {headerStats.burnUsdPerMin != null && headerStats.burnUsdPerMin > 0 && (
                  <>
                    <span class="text-[var(--color-subtle-foreground)]">·</span>
                    <span
                      class="tabular-nums font-mono text-[var(--color-money)]/80"
                      title="Trailing 5-minute burn rate"
                    >
                      {fmtBurn(headerStats.burnUsdPerMin)}
                    </span>
                  </>
                )}
                <span class="text-[var(--color-subtle-foreground)]">·</span>
                <span class="tabular-nums font-mono">{headerStats.turns} turns</span>
                <span class="text-[var(--color-subtle-foreground)]">·</span>
                <span class="tabular-nums font-mono">{headerStats.sessions} sessions</span>
                {headerStats.errorRate != null && headerStats.errorRate > 0 && (
                  <>
                    <span class="text-[var(--color-subtle-foreground)]">·</span>
                    <span
                      class="tabular-nums font-mono text-[var(--color-danger)] font-medium"
                      title="Fraction of recent turns with status ≥ 400"
                    >
                      {(headerStats.errorRate * 100).toFixed(headerStats.errorRate < 0.1 ? 1 : 0)}% err
                    </span>
                  </>
                )}
                {headerStats.rateLimit && headerStats.rateLimit.tokLimit > 0 && (() => {
                  const { tokRemaining, tokLimit } = headerStats.rateLimit;
                  const pct = Math.max(0, Math.min(100, (tokRemaining / tokLimit) * 100));
                  const color = pct < 15 ? "var(--color-danger)" : pct < 40 ? "var(--color-warn)" : "var(--color-good)";
                  return (
                    <>
                      <span class="text-[var(--color-subtle-foreground)]">·</span>
                      <span
                        class="inline-flex items-center gap-1.5 tabular-nums"
                        title={`Anthropic rate-limit — ${tokRemaining.toLocaleString()} / ${tokLimit.toLocaleString()} input tokens remaining this window`}
                      >
                        <span
                          class="inline-flex overflow-hidden rounded-full bg-[var(--color-border)]"
                          style={`width:32px;height:4px;`}
                        >
                          <span
                            style={`width:${pct}%;height:100%;background:${color};`}
                          />
                        </span>
                        <span class="font-mono text-[var(--color-muted-foreground)]">
                          {Math.round(pct)}%
                        </span>
                      </span>
                    </>
                  );
                })()}
              </div>
            )
          }
        </div>
      </div>
    </header>
    <main class="px-6 py-8 w-full max-w-7xl mx-auto">
      <slot />
    </main>
    </div>

    <script>
      // --- 1-second ticker for every [data-ts] element. ---
      // Updates inner text to the current "Xs / Xm / Xh / Xd" ago value.
      function fmtAgo(ms: number): string {
        const diff = Date.now() - ms;
        const s = Math.max(0, Math.floor(diff / 1000));
        if (s < 60) return `${s}s`;
        const m = Math.floor(s / 60);
        if (m < 60) return `${m}m`;
        const h = Math.floor(m / 60);
        if (h < 24) return `${h}h`;
        return `${Math.floor(h / 24)}d`;
      }
      function refreshAges() {
        document.querySelectorAll<HTMLElement>("[data-ts]").forEach((el) => {
          const ts = Number(el.dataset.ts);
          if (!Number.isFinite(ts)) return;
          const suffix = el.dataset.tsSuffix ?? "";
          el.textContent = fmtAgo(ts) + suffix;
        });
      }
      setInterval(refreshAges, 1000);

      // --- 10-second live refresh. ---
      // Fetches the current page, parses, and swaps every [data-live-region]
      // block in place. The chart section is excluded so the React island
      // keeps its state.
      const POLL_MS = 5_000;
      let polling = false;
      async function pollRefresh() {
        if (polling || document.hidden) return;
        polling = true;
        try {
          const res = await fetch(window.location.pathname, {
            credentials: "include",
            headers: { Accept: "text/html" },
            cache: "no-store",
          });
          if (!res.ok) return;
          const html = await res.text();
          const doc = new DOMParser().parseFromString(html, "text/html");
          const freshRegions = doc.querySelectorAll<HTMLElement>("[data-live-region]");
          freshRegions.forEach((fresh) => {
            const name = fresh.getAttribute("data-live-region");
            if (!name) return;
            const target = document.querySelector(`[data-live-region="${name}"]`);
            if (!target) return;
            // For the sessions region, diff per-card lastTs so we can glow
            // cards whose most-recent turn advanced.
            const prevTs = new Map<string, number>();
            if (name === "sessions") {
              target
                .querySelectorAll<HTMLElement>("[data-session-card]")
                .forEach((el) => {
                  const id = el.getAttribute("data-session-id") ?? "";
                  const ts = Number(el.getAttribute("data-last-ts") ?? "0");
                  if (id) prevTs.set(id, ts);
                });
            }
            target.innerHTML = fresh.innerHTML;
            if (name === "sessions" && prevTs.size > 0) {
              target
                .querySelectorAll<HTMLElement>("[data-session-card]")
                .forEach((el) => {
                  const id = el.getAttribute("data-session-id") ?? "";
                  const ts = Number(el.getAttribute("data-last-ts") ?? "0");
                  const before = prevTs.get(id);
                  if (before != null && ts > before) {
                    el.classList.remove("glow");
                    // Force reflow so re-adding the class restarts the animation.
                    void el.offsetWidth;
                    el.classList.add("glow");
                  }
                });
            }
          });
          refreshAges();
        } catch (e) {
          // swallow — next tick will retry
        } finally {
          polling = false;
        }
      }
      setInterval(pollRefresh, POLL_MS);
      // Also refresh immediately on tab focus so you don't see stale data.
      document.addEventListener("visibilitychange", () => {
        if (!document.hidden) pollRefresh();
      });
    </script>
  </body>
</html>
