---
export const prerender = false;

import { env } from "cloudflare:workers";
import Base from "@/layouts/Base.astro";
import KpiCard from "@/components/KpiCard.astro";
import Sparkline from "@/components/Sparkline.astro";
import TokenChart from "@/components/TokenChart";
import RecentTurnsTable from "@/components/RecentTurnsTable";
import RowsPoller from "@/components/RowsPoller";
import { readUserHash } from "@/lib/cookie";
import { getLinkedHash, readCfAccessEmail } from "@/lib/links";
import { getStats, getRecent, getSessionEnds, type TransactionRow, type SessionEnds } from "@/lib/store";
import { estimateCostUsd, fmtInt, fmtUsd, fmtAgo, fmtDuration } from "@/lib/format";
import {
  MessageSquare,
  ArrowUpFromLine,
  Database,
  DollarSign,
} from "lucide-react";

const domain = env.DOMAIN ?? "your-proxy";

// Identity resolution priority:
//   1. CF Access email → KV link → user_hash (auto-populated by the proxy
//      on every request; works for free if Anthropic email == CF Access email)
//   2. Cookie (manual paste fallback for dev-local with no CF Access)
//   3. Empty state — no proxy traffic seen yet under this email
const cfEmail = readCfAccessEmail(Astro.request);
const linked = await getLinkedHash(env.SESSION, cfEmail);
const cookieHash = readUserHash(Astro.request.headers.get("cookie"));
const userHash = linked ?? cookieHash;

const ns = env.USER_STORE;

let stats: Awaited<ReturnType<typeof getStats>> | null = null;
let rows: TransactionRow[] = [];
let sessionEnds: SessionEnds = {};
let loadErr: string | null = null;
if (userHash) {
  try {
    [stats, rows, sessionEnds] = await Promise.all([
      getStats(ns, userHash),
      getRecent(ns, userHash),
      getSessionEnds(ns, userHash),
    ]);
  } catch (e) {
    loadErr = e instanceof Error ? e.message : String(e);
  }
}

// Chronological: oldest → newest for chart + rolling sparklines
const chron = [...rows].sort((a, b) => a.ts - b.ts);

const totalCost = rows.reduce((acc, r) => acc + estimateCostUsd(r), 0);
const sessions = new Set(rows.map((r) => r.session_id).filter(Boolean)).size;

const cacheRate = (() => {
  if (!stats) return 0;
  const denom = stats.input_tokens + stats.cache_read + stats.cache_creation;
  return denom > 0 ? stats.cache_read / denom : 0;
})();

// Cache TTL split (only present on newer API responses; may be null on old rows).
const cache5mTotal = rows.reduce((a, r) => a + (r.cache_creation_5m ?? 0), 0);
const cache1hTotal = rows.reduce((a, r) => a + (r.cache_creation_1h ?? 0), 0);
const ttlKnown = cache5mTotal + cache1hTotal > 0;
const longTtlPct = ttlKnown
  ? (cache1hTotal / (cache5mTotal + cache1hTotal)) * 100
  : 0;

const avgLatency =
  rows.length > 0 ? rows.reduce((a, r) => a + r.elapsed_ms, 0) / rows.length : 0;

// Sparklines (chronological)
const sparkTurns = (() => {
  if (chron.length < 2) return chron.map((_, i) => i + 1);
  // Per-minute rate: bucket by minute, trailing 20 buckets
  const buckets = new Map<number, number>();
  for (const r of chron) {
    const m = Math.floor(r.ts / 60_000);
    buckets.set(m, (buckets.get(m) ?? 0) + 1);
  }
  const sorted = [...buckets.entries()].sort((a, b) => a[0] - b[0]);
  return sorted.slice(-20).map(([, n]) => n);
})();
const sparkOutput = chron.map((r) => r.output_tokens).slice(-30);
const sparkCache = (() => {
  // Rolling-5 cache-read hit ratio
  const arr: number[] = [];
  const window: TransactionRow[] = [];
  for (const r of chron) {
    window.push(r);
    if (window.length > 5) window.shift();
    const d = window.reduce(
      (a, x) => a + x.input_tokens + x.cache_read + x.cache_creation,
      0,
    );
    const num = window.reduce((a, x) => a + x.cache_read, 0);
    arr.push(d > 0 ? (num / d) * 100 : 0);
  }
  return arr.slice(-30);
})();
const sparkCost = chron.map((r) => estimateCostUsd(r)).slice(-30);

// Main chart: skip probe/auth rows, take last 30 real turns. Points are
// equally spaced on x (categorical), which interpolates across idle gaps —
// preferred over time-scaled breaks for this dataset since gaps tend to
// crush the active bands into unreadable slivers.
const chartData = chron
  .filter((r) => r.output_tokens > 0 || r.input_tokens > 50)
  .slice(-30)
  .map((r) => ({
    ts: r.ts,
    input: Math.max(r.input_tokens, 1),
    output: Math.max(r.output_tokens, 1),
    cache_read: Math.max(r.cache_read, 1),
    cache_creation: Math.max(r.cache_creation, 1),
    cost: estimateCostUsd(r),
  }));

// Attribute rows to sessions.
type SessionAgg = {
  id: string;
  turns: number;
  firstTs: number;
  lastTs: number;
  cost: number;
  output: number;
  cacheRead: number;
  models: Map<string, number>;
};
const sessionMap = new Map<string, SessionAgg>();
for (const r of rows) {
  if (!r.session_id) continue;
  const cur =
    sessionMap.get(r.session_id) ??
    ({
      id: r.session_id,
      turns: 0,
      firstTs: r.ts,
      lastTs: r.ts,
      cost: 0,
      output: 0,
      cacheRead: 0,
      models: new Map(),
    } satisfies SessionAgg);
  cur.turns += 1;
  cur.firstTs = Math.min(cur.firstTs, r.ts);
  cur.lastTs = Math.max(cur.lastTs, r.ts);
  cur.cost += estimateCostUsd(r);
  cur.output += r.output_tokens;
  cur.cacheRead += r.cache_read;
  if (r.model) {
    cur.models.set(r.model, (cur.models.get(r.model) ?? 0) + 1);
  }
  sessionMap.set(r.session_id, cur);
}
// A session is "active" if its most recent turn lands within this window.
const ACTIVE_WINDOW_MS = 3 * 60_000;
const now = Date.now();
// A session is active iff (a) last turn is within the window AND (b) no
// SessionEnd marker has been recorded at or after that last turn.
const isActive = (s: SessionAgg) => {
  if (now - s.lastTs >= ACTIVE_WINDOW_MS) return false;
  const endedAt = sessionEnds[s.id];
  return endedAt == null || endedAt < s.lastTs;
};
// Active sessions sort ahead of inactive ones; within each group, most
// recent turn first. An idle-but-recent session should never outrank a
// live one just because its last turn happened to land more recently.
const sessionList = [...sessionMap.values()].sort((a, b) => {
  const aa = isActive(a) ? 1 : 0;
  const ba = isActive(b) ? 1 : 0;
  if (aa !== ba) return ba - aa;
  return b.lastTs - a.lastTs;
});
const activeSession = sessionList.find(isActive) ?? null;

function shortSession(id: string): string {
  return id.slice(0, 8);
}
function sessionModels(s: SessionAgg): string {
  const top = [...s.models.entries()].sort((a, b) => b[1] - a[1])[0];
  if (!top) return "—";
  const name = top[0].replace(/-\d{8}$/, "").replace(/^claude-/, "");
  return s.models.size > 1 ? `${name} +${s.models.size - 1}` : name;
}

// Trailing 5-minute burn rate ($/min).
const fiveMinAgo = now - 5 * 60_000;
const recentSpend = rows
  .filter((r) => r.ts >= fiveMinAgo)
  .reduce((a, r) => a + estimateCostUsd(r), 0);
const burnUsdPerMin = recentSpend / 5;

// Error rate across the last 50 turns (rows come desc from /recent).
const last50 = rows.slice(0, 50);
const errorRate =
  last50.length > 0
    ? last50.filter((r) => r.status >= 400).length / last50.length
    : 0;

// Most recent rate-limit snapshot. Rows come sorted desc, so the first hit wins.
const rlRow = rows.find(
  (r) => r.rl_tok_remaining != null && r.rl_tok_limit != null && r.rl_tok_limit > 0,
);
const rateLimit =
  rlRow && rlRow.rl_tok_remaining != null && rlRow.rl_tok_limit != null
    ? { tokRemaining: rlRow.rl_tok_remaining, tokLimit: rlRow.rl_tok_limit }
    : null;

---

<Base
  title="llmetry — overview"
  headerStats={{
    spendUsd: totalCost,
    turns: rows.length,
    sessions,
    activeSession: activeSession ? shortSession(activeSession.id) : null,
    burnUsdPerMin,
    errorRate,
    rateLimit,
  }}
  activePath="/"
>
  <RowsPoller client:load intervalMs={1000} />
  <div class="mb-7 flex items-baseline justify-between">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight">Overview</h1>
      <p class="text-xs text-[var(--color-subtle-foreground)] mt-1">
        Last {rows.length} transactions
      </p>
    </div>
    <p class="text-xs text-[var(--color-subtle-foreground)] font-mono">{userHash ?? cfEmail ?? "no identity"}</p>
  </div>

  {
    !userHash && (
      <div class="mb-6 px-4 py-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] text-sm text-[var(--color-muted-foreground)]">
        No Claude Code activity yet under <span class="font-mono text-[var(--color-foreground)]">{cfEmail ?? "this session"}</span>. Run a request through this proxy and refresh — the link is created automatically.
      </div>
    )
  }

  {
    loadErr && (
      <div class="mb-6 px-4 py-3 rounded-xl border border-[var(--color-danger-muted)] bg-[var(--color-danger-muted)] text-[var(--color-danger)] text-sm">
        Failed to load from DO: {loadErr}
      </div>
    )
  }

  {
    stats && (
      <section class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8" data-live-region="kpis">
        <KpiCard
          label="Turns"
          value={fmtInt(stats.turns)}
          sub={`${fmtDuration(avgLatency)} avg`}
          accent="neutral"
          sparkValues={sparkTurns}
          sparkMode="line"
        >
          <MessageSquare slot="icon" size={16} />
        </KpiCard>
        <KpiCard
          label="Output tokens"
          value={fmtInt(stats.output_tokens)}
          sub={`${fmtInt(stats.input_tokens)} input`}
          accent="volume"
          sparkValues={sparkOutput}
          sparkMode="bars"
        >
          <ArrowUpFromLine slot="icon" size={16} />
        </KpiCard>
        <KpiCard
          label="Cache hit"
          value={`${(cacheRate * 100).toFixed(0)}%`}
          sub={
            ttlKnown
              ? `${fmtInt(stats.cache_read)} read · ${longTtlPct.toFixed(0)}% 1h TTL`
              : `${fmtInt(stats.cache_read)} read`
          }
          accent="volume"
          sparkValues={sparkCache}
          sparkMode="line"
        >
          <Database slot="icon" size={16} />
        </KpiCard>
        <KpiCard
          label="Cost (window)"
          value={fmtUsd(totalCost)}
          sub={`${rows.length} turns · ${sessions} sessions`}
          accent="money"
          sparkValues={sparkCost}
          sparkMode="bars"
        >
          <DollarSign slot="icon" size={16} />
        </KpiCard>
      </section>
    )
  }

  {
    chartData.length > 0 && (
      <section class="card p-5 mb-8">
        <div class="flex items-baseline justify-between mb-1">
          <h2 class="text-sm font-medium">Tokens &amp; cost over time</h2>
          <div class="flex items-center gap-3 text-[0.6875rem] uppercase tracking-[0.08em] text-[var(--color-muted-foreground)]">
            <span class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-sm bg-[var(--color-chart-1)]" /> cache read
            </span>
            <span class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-sm bg-[var(--color-chart-2)]" /> cache create
            </span>
            <span class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-sm bg-[var(--color-chart-4)]" /> output
            </span>
            <span class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-sm bg-[var(--color-chart-5)]" /> input
            </span>
            <span class="flex items-center gap-1.5">
              <span class="w-2 h-0.5 bg-[var(--color-money)]" /> cost ($)
            </span>
          </div>
        </div>
        <p class="text-xs text-[var(--color-subtle-foreground)] mb-4">
          Stacked token composition (log scale) with per-turn cost overlay. Last {chartData.length} turns.
        </p>
        <TokenChart client:load initialRows={rows} />
      </section>
    )
  }

  {
    sessionList.length > 0 && (
      <section class="mb-8" data-live-region="sessions">
        <div class="flex items-baseline justify-between mb-3">
          <h2 class="text-sm font-medium">By session</h2>
          <span class="text-xs text-[var(--color-subtle-foreground)] tabular-nums">
            {sessionList.length} sessions
          </span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-3">
          {sessionList.slice(0, 8).map((s) => {
            const active = isActive(s);
            return (
            <a
              href={`/session/${s.id}`}
              class={`card card-hover p-4 block ${active ? "ring-1 ring-[var(--color-good-muted)] ring-offset-0" : ""}`}
              data-session-card
              data-session-id={s.id}
              data-last-ts={s.lastTs}
            >
              <div class="flex items-baseline justify-between mb-2.5">
                <div class="flex items-center gap-2">
                  <code class="font-mono text-xs text-[var(--color-volume)]">{shortSession(s.id)}</code>
                  {active && (
                    <span class="flex items-center gap-1 text-[0.625rem] uppercase tracking-wider text-[var(--color-good)]">
                      <span class="live-dot" />
                      active
                    </span>
                  )}
                </div>
                <span class="text-[0.6875rem] uppercase tracking-wider text-[var(--color-subtle-foreground)]">
                  <span data-ts={s.lastTs} data-ts-suffix=" ago">{fmtAgo(s.lastTs)} ago</span>
                </span>
              </div>
              <div class="flex items-end justify-between">
                <div>
                  <p class="font-mono text-xl font-semibold tabular-nums">
                    {s.turns}
                    <span class="text-[var(--color-subtle-foreground)] text-xs font-normal ml-1">turns</span>
                  </p>
                  <p class="text-xs text-[var(--color-muted-foreground)] mt-1 font-mono">
                    {sessionModels(s)}
                  </p>
                </div>
                <div class="text-right">
                  <p class="font-mono text-sm tabular-nums text-[var(--color-money)]">{fmtUsd(s.cost)}</p>
                  <p class="text-xs text-[var(--color-subtle-foreground)] tabular-nums mt-1">
                    {fmtDuration(s.lastTs - s.firstTs)}
                  </p>
                </div>
              </div>
            </a>
          );
          })}
        </div>
      </section>
    )
  }

  <RecentTurnsTable client:load initialRows={rows} />
</Base>
